# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python
agent/venv/
agent/models/
__pycache__/
*.pyc

# local git worktrees
/.worktrees/

# opencode config (user-specific)
opencode.json

# local database
*.db

# RAG vector store (generated, rebuilt via scripts/build_knowledge_base.py)
agent/knowledge/chroma_db/
